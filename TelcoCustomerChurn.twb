      <aliases enabled='yes' />
      <column caption='TenureGroup' datatype='string' name='[Calculation_0773559027277825]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [tenure] &lt;= 6 THEN &quot;0-6 Months&quot;&#13;&#10;ELSEIF [tenure] &lt;= 12 THEN &quot;6-12 Months&quot;&#13;&#10;ELSEIF [tenure] &lt;= 24 THEN &quot;1-2 Years&quot;&#13;&#10;ELSEIF [tenure] &lt;= 48 THEN &quot;2-4 Years&quot;&#13;&#10;ELSE &quot;4+ Years&quot;&#13;&#10;END' />
      </column>
      <column caption='Churn Flag' datatype='string' name='[Calculation_0811492125315073]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Churn] = &quot;Yes&quot; THEN &quot;Churned&quot;&#13;&#10;ELSE &quot;Retained&quot;&#13;&#10;END' />
      </column>
      <column caption='Churn Rate' datatype='real' default-format='p0.00%' name='[Calculation_0811492125581314]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [Churn] = &quot;Yes&quot; THEN [customerID] END)&#13;&#10;/ COUNTD([customerID])' />
      </column>
      <column caption='Revenue Segment' datatype='string' name='[Calculation_0811492126302212]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [MonthlyCharges] &lt; 30 THEN &quot;Low&quot;&#13;&#10;ELSEIF [MonthlyCharges] &lt; 70 THEN &quot;Medium&quot;&#13;&#10;ELSE &quot;High&quot;&#13;&#10;END' />
      </column>
      <column caption='Churn %' datatype='real' default-format='p0.00%' name='[Calculation_0811492142178314]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Churn] = &quot;Yes&quot; THEN 1 ELSE 0 END)&#13;&#10;/ COUNT([customerID])' />
      </column>
